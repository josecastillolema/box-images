# podman build -t localhost/dpu-sim .

FROM registry.fedoraproject.org/fedora:44

# Disable h264 repo
RUN sed -i -e "s,enabled=1,enabled=0,g" /etc/yum.repos.d/fedora-cisco-openh264.repo

# Install packages
RUN dnf install -y \
    curl \
    git \
    helm \
    libvirt-devel \
    podman-remote \
    python3 \
    python3-pip \
    wget \
    && dnf clean all \
    && rm -rf /var/cache/dnf

# Install jinjanate (required by OVN-Kubernetes daemonset.sh)
RUN pip3 install jinjanator

# Install kind
RUN curl -Lo /usr/local/bin/kind https://kind.sigs.k8s.io/dl/latest/kind-linux-amd64 \
    && chmod +x /usr/local/bin/kind

# Install kubectl
RUN curl -Lo /usr/local/bin/kubectl "https://dl.k8s.io/release/$(curl -Ls https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
    && chmod +x /usr/local/bin/kubectl

# Symlink podman-remote as podman
RUN ln -s /usr/bin/podman-remote /usr/bin/podman

# Host prerequisites (run on the host before creating the container):
RUN echo "sudo sysctl -w fs.inotify.max_user_instances=8192 fs.inotify.max_user_watches=1048576 fs.inotify.max_queued_events=32768"
RUN echo "sudo modprobe openvswitch"
RUN echo "distrobox create --name dpu-dev --image localhost/dpu-sim --root"
RUN echo "distrobox enter --root dpu-dev"
